# Copy to .env for local experiments (optional).
# Production values belong in GitHub Actions / Cloudflare secrets.

# --- GitHub Actions (daily-tracker workflow) ---
VERCEL_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# --- Cloudflare Worker (workers/github-cron) ---
# Fine-grained PAT: repo gftracker, Actions read/write
GITHUB_PAT=
# Optional: require ?secret= on POST /trigger
CRON_SECRET=
